type arr = array $s8 10

func println $arr = native println

public func main = #main
main:
    array $arr
    store %0

    push $s32 2
    store %1

    push $s32 0
loop:
    dup
    load %1
    ge
    jnz #end
body:
    dup
    load %0
    swap
    push $s8 69
    set

    push $s32 1
    add

    jmp #loop
end:
    drop
    load %0
    call $arr println
    ret
